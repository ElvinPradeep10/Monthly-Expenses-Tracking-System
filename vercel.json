{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "dest": "/api/index.js"
    },
    {
      "src": "^/css/(.*)$",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "^/js/(.*)$",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "^/dashboard.html$",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "^/login.html$",
      "dest": "/frontend/login.html"
    },
    {
      "src": "^/signup.html$",
      "dest": "/frontend/signup.html"
    },
    {
      "src": "^/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
