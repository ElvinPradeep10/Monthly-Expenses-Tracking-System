{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "frontend/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/frontend/index.html" },
    { "src": "^/dashboard.html$", "dest": "/frontend/dashboard.html" },
    { "src": "^/login.html$", "dest": "/frontend/login.html" },
    { "src": "^/signup.html$", "dest": "/frontend/signup.html" },
    { "src": "^/css/(.*)$", "dest": "/frontend/css/$1" },
    { "src": "^/js/(.*)$", "dest": "/frontend/js/$1" },
    { "src": "^/api/auth$", "dest": "/api/auth.js" },
    { "src": "^/api/expenses(.*)$", "dest": "/api/expenses.js" },
    { "src": "^/(.*)$", "dest": "/frontend/index.html" }
  ]
}
